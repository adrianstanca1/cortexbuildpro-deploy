# GitHub OAuth Configuration
# Get these from your GitHub App settings: https://github.com/settings/apps
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend OAuth Client IDs (VITE_ prefix for client-side access)
# These should match the server-side credentials above
VITE_GITHUB_CLIENT_ID=your_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Server Configuration
PORT=3000
NODE_ENV=staging

# Session Secret (generate a secure random string)
SESSION_SECRET=your_secure_session_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Ollama Configuration (for local AI models)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nemotron-3-super:latest

# AI Provider Selection
# Set to 'ollama' to use local models, 'gemini' for cloud (default: gemini)
DEFAULT_AI_PROVIDER=gemini

# Default model overrides
# DEFAULT_GEMINI_MODEL=gemini-3-pro-preview
# OLLAMA_MODEL=nemotron-3-super:latest

# Database (optional - for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/buildpro